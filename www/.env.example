# ──────────────────────────────────────────────────────────────────────────────
# SK Jurídico IA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# ──────────────────────────────────────────────────────────────────────────────

# ── OBRIGATÓRIAS ──────────────────────────────────────────────────────────────

# Porta do servidor (padrão: 8080)
PORT=8080

# Banco de dados PostgreSQL
# Opção 1: PostgreSQL local (instale o PostgreSQL ou use docker-compose.yml)
DATABASE_URL=postgresql://sk_user:sk_pass@localhost:5432/sk_juridico

# Opção 2: Neon (nuvem gratuita) — https://neon.tech
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# Opção 3: Supabase (nuvem gratuita) — https://supabase.com
# DATABASE_URL=postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres

# Chave secreta para sessões (use uma string aleatória longa)
SESSION_SECRET=sk-juridico-secret-mude-esta-chave-2025

# ── IA — Pelo menos uma chave é necessária ────────────────────────────────────

# Google Gemini (gratuito) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq (ultra-rápido, gratuito) — https://console.groq.com/keys
GROQ_API_KEY=

# Perplexity (busca web) — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenRouter (100+ modelos) — https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# xAI Grok — https://console.x.ai
XAI_API_KEY=

# Together AI — https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# ── OPCIONAIS ─────────────────────────────────────────────────────────────────

# Proteção por senha (se definido, o app pede senha ao abrir)
APP_PASSWORD=

# DataJud CNJ — https://datajud-wiki.cnj.jus.br
DATAJUD_API_KEY=

# Google Vision (OCR de imagens) — https://console.cloud.google.com
GOOGLE_VISION_API_KEY=

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_ACCESS_TOKEN=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

# Assinatura digital — BirdID (Soluti)
BIRDID_CLIENT_ID=
BIRDID_CLIENT_SECRET=

# Assinatura digital — VIDaaS (Serpro)
VIDAAS_CLIENT_ID=
VIDAAS_CLIENT_SECRET=

# Firebase Cloud Messaging (push notifications)
FCM_SERVER_KEY=
FCM_PROJECT_ID=
FCM_VAPID_KEY=

# JWT para autenticação multi-usuário
JWT_SECRET=sk-juridico-jwt-secret-mude-esta-chave

# Node environment
NODE_ENV=production
